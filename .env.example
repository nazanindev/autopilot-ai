ANTHROPIC_API_KEY=sk-ant-...        # for flow utility calls (ship, ci-review, Haiku summaries)
AP_PLAN=pro                         # your claude.ai plan: pro | max5 | max20 | api_only

LANGFUSE_PUBLIC_KEY=pk-lf-...       # optional — free at cloud.langfuse.com
LANGFUSE_SECRET_KEY=sk-lf-...       # optional
LANGFUSE_HOST=https://cloud.langfuse.com

# Optional overrides
# Permission mode for `claude -p` under flow (default: bypassPermissions). Pretool hook still enforces bash allowlist + step budget.
# AP_CLAUDE_PERMISSION_MODE=bypassPermissions
AP_DB_PATH=~/.autopilot/costs.duckdb
AP_BUDGET_USD=1.00                  # api utility spend gate (overrides api_spend_gate_usd in constraints.yaml)
AP_NO_SPAWN=0

# Set to 1 to bill Claude Code sessions via API key instead of subscription.
# WARNING: set a spend cap in the Anthropic console first — sessions can be 2-10M tokens.
# AP_FORCE_API_KEY=0
